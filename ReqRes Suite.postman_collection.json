    {
      "name": "Auth",
      "item": [
        {
          "name": "Login válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token existe\", () => {\r",
                  "    const res = pm.response.json();\r",
                  "    pm.expect(res.token).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token es string\", () => {\r",
                  "    const res = pm.response.json();\r",
                  "    pm.expect(res.token).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Respuesta en menos de 2000ms\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              }
